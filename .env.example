# Mode: paper | backtest | live
# `live` requires an explicit --i-understand-this-is-real-money flag at the CLI.
TP_MODE=paper

# Postgres / TimescaleDB
TP_DB_URL=postgresql+psycopg://tp:tp@localhost:5432/tradingplatform

# Redis (pub/sub + cache)
TP_REDIS_URL=redis://localhost:6379/0

# --- Saxo OpenAPI (SIM) ---
# https://www.developer.saxo/openapi/learn/environments
SAXO_BASE_URL=https://gateway.saxobank.com/sim/openapi
SAXO_TOKEN=                      # 24h dev token from developer portal
SAXO_APP_KEY=
SAXO_APP_SECRET=

# --- IBKR ---
# When using TWS / IB Gateway with ib_insync. Paper port = 7497, live = 7496.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=42

# --- Logging ---
TP_LOG_LEVEL=INFO

# --- Admin seeding (used by `make seed-admin`) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme-min-12-chars
